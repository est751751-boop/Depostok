# PHP dosyalarına doğrudan erişim (api.php hariç)
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# Güvenlik başlıkları
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" "expr=%{REQUEST_URI} =~ m#api\.php#"
</IfModule>

# storage klasörüne dışarıdan erişimi engelle
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^storage/ - [F,L]
</IfModule>
